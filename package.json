{
  "name": "oneai-recordings",
  "version": "0.1.0",
  "description": "Self-hosted meeting recorder for Google Meet, with provider architecture for Zoom and other platforms.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "oneai-recordings": "src/cli.js"
  },
  "scripts": {
    "api": "node src/cli.js api",
    "scheduler": "node src/cli.js scheduler",
    "record": "node src/cli.js record",
    "auth:drive": "node src/cli.js auth:drive",
    "add-job": "node src/cli.js add-job",
    "doctor": "node src/cli.js doctor",
    "auth:calendar": "node src/cli.js auth:calendar",
    "calendar:sync": "node src/cli.js calendar:sync",
    "legacy:api": "node src/cli.js legacy:api",
    "legacy:scheduler": "node src/cli.js legacy:scheduler",
    "legacy:record": "node src/cli.js legacy:record",
    "legacy:auth:drive": "node src/cli.js legacy:auth-drive",
    "legacy:add-job": "node src/cli.js legacy:add-job",
    "legacy:doctor": "node src/cli.js legacy:doctor",
    "legacy:auth:calendar": "node src/cli.js legacy:auth-calendar",
    "legacy:calendar:sync": "node src/cli.js legacy:calendar-sync",
    "modular:api": "node src/cli.js modular:api",
    "modular:scheduler": "node src/cli.js modular:scheduler",
    "modular:record": "node src/cli.js modular:record",
    "modular:doctor": "node src/cli.js modular:doctor",
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "googleapis": "^144.0.0",
    "puppeteer-core": "^23.11.1"
  },
  "engines": {
    "node": ">=20"
  }
}
