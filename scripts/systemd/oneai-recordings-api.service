[Unit]
Description=OneAI Recordings API (legacy Google Meet recorder)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/oneai-recordings
Environment=NODE_ENV=production
Environment=ONEAI_APP_DIR=/opt/oneai-recordings
ExecStart=/usr/bin/node src/cli.js legacy:api
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
